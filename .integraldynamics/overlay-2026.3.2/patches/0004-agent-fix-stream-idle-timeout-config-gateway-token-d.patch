+        markRunActivity?.();
+        void params.onAgentEvent?.(evt);
+      };
+
       const subscription = subscribeEmbeddedPiSession({
         session: activeSession,
         runId: params.runId,
@@ -1182,7 +1201,7 @@ export async function runEmbeddedAttempt(
