{
  // Merge into your openclaw.json
  // Goal: corporate teamwork with explicit role ownership.
  "session": {
    "dmScope": "per-account-channel-peer"
  },
  "tools": {
    "message": {
      "crossContext": {
        "allowWithinProvider": false,
        "allowAcrossProviders": false
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "nvidia/minimaxai/minimax-m2.5",
        "fallbacks": []
      },
      "timeoutSeconds": 120
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "name": "CEO Orchestrator",
        "identity": { "name": "A1-CEO" },
        "subagents": { "allowAgents": ["growth", "delivery", "finance", "audit", "ops", "watcher"] },
        "skills": ["integral-dynamics-expert", "healthcheck"],
        "tools": {
          "deny": [],
          "elevated": { "enabled": false }
        }
      },
      {
        "id": "growth",
        "name": "Growth",
        "identity": { "name": "A1-GROWTH" },
        "skills": ["integral-dynamics-expert", "gh-issues"],
        "tools": {
          "deny": [],
          "elevated": { "enabled": false }
        }
      },
      {
        "id": "delivery",
        "name": "Delivery",
        "identity": { "name": "A1-DELIVERY" },
        "skills": ["integral-dynamics-expert"],
        "tools": {
          "elevated": { "enabled": false }
        }
      },
      {
        "id": "finance",
        "name": "FinanceRisk",
        "identity": { "name": "A1-FINANCE" },
        "skills": ["integral-dynamics-expert"],
        "tools": {
          "deny": ["gateway", "cron"],
          "elevated": { "enabled": false }
        }
      },
      {
        "id": "audit",
        "name": "ComplianceAudit",
        "identity": { "name": "A1-AUDIT" },
        "skills": ["integral-dynamics-expert", "healthcheck"],
        "tools": {
          "deny": ["gateway", "cron"],
          "elevated": { "enabled": false }
        }
      },
      {
        "id": "ops",
        "name": "OpsReliability",
        "identity": { "name": "A1-OPS" },
        "skills": ["integral-dynamics-expert", "healthcheck"],
        "tools": {
          "deny": [],
          "elevated": { "enabled": false }
        }
      },
      {
        "id": "watcher",
        "name": "WatcherObservability",
        "identity": { "name": "A1-WATCHER" },
        "skills": ["integral-dynamics-expert", "healthcheck"],
        "tools": {
          "deny": [],
          "elevated": { "enabled": false }
        }
      }
    ]
  },
  "messages": {
    "responsePrefix": "[{identity.name}|{model}]"
  }
}
